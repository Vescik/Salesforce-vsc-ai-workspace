{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "AI Workspace: Setup",
      "type": "shell",
      "command": "pip install -e . --quiet && make setup",
      "problemMatcher": []
    },
    {
      "label": "AI Workspace: Configure",
      "type": "shell",
      "command": "make configure",
      "problemMatcher": []
    },
    {
      "label": "AI Workspace: Doctor",
      "type": "shell",
      "command": "make doctor",
      "problemMatcher": []
    },
    {
      "label": "AI Workspace: Doctor Strict",
      "type": "shell",
      "command": "make doctor-strict",
      "problemMatcher": []
    },
    {
      "label": "AI Workspace: First Run",
      "type": "shell",
      "command": "pip install -e . --quiet && make first-run",
      "problemMatcher": []
    },
    {
      "label": "Salesforce: Login IntDev",
      "type": "shell",
      "command": "sf org login web --alias ${input:sfDevOrgAlias}",
      "problemMatcher": []
    },
    {
      "label": "Knowledge: Sync",
      "type": "shell",
      "command": "make knowledge-sync KB_REPO=\"${input:kbRepo}\" KB_BRANCH=\"${input:kbBranch}\"",
      "problemMatcher": []
    },
    {
      "label": "Knowledge: Index",
      "type": "shell",
      "command": "make knowledge-index",
      "problemMatcher": []
    },
    {
      "label": "Azure Wiki: Dry Run Publication",
      "type": "shell",
      "command": "make wiki-dry-run WORK_ITEM=${input:workItemId} WIKI_TITLE=\"${input:wikiTitle}\" WIKI_SOURCE=\"${input:wikiSource}\" AZURE_WIKI_REPO=\"${input:azureWikiRepo}\" AZURE_WIKI_BRANCH=\"${input:azureWikiBranch}\" WIKI_MODULE=\"${input:wikiModule}\" WIKI_TARGET_PATH=\"${input:wikiTargetPath}\"",
      "problemMatcher": []
    },
    {
      "label": "Azure Wiki: Prepare Draft Branch",
      "type": "shell",
      "command": "make wiki-prepare-branch WORK_ITEM=${input:workItemId} WIKI_TITLE=\"${input:wikiTitle}\" WIKI_SOURCE=\"${input:wikiSource}\" AZURE_WIKI_REPO=\"${input:azureWikiRepo}\" AZURE_WIKI_BRANCH=\"${input:azureWikiBranch}\" WIKI_MODULE=\"${input:wikiModule}\" WIKI_TARGET_PATH=\"${input:wikiTargetPath}\"",
      "problemMatcher": []
    },
    {
      "label": "Azure Wiki: Push Approved Branch",
      "type": "shell",
      "command": "make wiki-push-approved WORK_ITEM=${input:workItemId} WIKI_TITLE=\"${input:wikiTitle}\" WIKI_SOURCE=\"${input:wikiSource}\" AZURE_WIKI_REPO=\"${input:azureWikiRepo}\" AZURE_WIKI_BRANCH=\"${input:azureWikiBranch}\" WIKI_MODULE=\"${input:wikiModule}\" WIKI_TARGET_PATH=\"${input:wikiTargetPath}\" WIKI_APPROVAL_NOTE=\"${input:wikiApprovalNote}\"",
      "problemMatcher": []
    },
    {
      "label": "Azure Wiki: Scan Wiki",
      "type": "shell",
      "command": "make wiki-scan AZURE_WIKI_VENDOR_DIR=\"${input:azureWikiVendorDir}\"",
      "problemMatcher": []
    },
    {
      "label": "Context: Build Work Item Context",
      "type": "shell",
      "command": "make ai-context WORK_ITEM=${input:workItemId} QUERY=\"${input:contextQuery}\"",
      "problemMatcher": []
    },
    {
      "label": "AI: Index Repo Metadata",
      "type": "shell",
      "command": "make ai-index-repo",
      "problemMatcher": []
    },
    {
      "label": "AI: Index Org Schema",
      "type": "shell",
      "command": "make ai-index-schema ORG=${input:sfOrgAlias}",
      "problemMatcher": []
    },
    {
      "label": "AI: Index Config Records",
      "type": "shell",
      "command": "make ai-index-config ORG=${input:sfOrgAlias}",
      "problemMatcher": []
    },
    {
      "label": "AI: Index All Context",
      "type": "shell",
      "command": "make ai-index-all ORG=${input:sfOrgAlias}",
      "problemMatcher": []
    },
    {
      "label": "AI: Build Context Pack",
      "type": "shell",
      "command": "make ai-context WORK_ITEM=${input:workItemId} QUERY=\"${input:contextQuery}\"",
      "problemMatcher": []
    },
    {
      "label": "AI: Build Example Context Pack",
      "type": "shell",
      "command": "make ai-context-example",
      "problemMatcher": []
    },
    {
      "label": "AI: List Outputs",
      "type": "shell",
      "command": "make ai-list-outputs WORK_ITEM=${input:workItemId}",
      "problemMatcher": []
    },
    {
      "label": "AI: Check Python Imports",
      "type": "shell",
      "command": "make ai-check-python",
      "problemMatcher": []
    },
    {
      "label": "AI: Run Unit Tests",
      "type": "shell",
      "command": "make test",
      "problemMatcher": []
    },
    {
      "label": "AI: Smoke Test Workspace",
      "type": "shell",
      "command": "make smoke",
      "problemMatcher": []
    },
    {
      "label": "AI: Work Item Precheck",
      "type": "shell",
      "command": "make wi-precheck WORK_ITEM=${input:workItemId} BASE_REF=${input:baseRef}",
      "problemMatcher": []
    },
    {
      "label": "AI: Work Item Precheck Strict",
      "type": "shell",
      "command": "make wi-precheck-strict WORK_ITEM=${input:workItemId} BASE_REF=${input:baseRef}",
      "problemMatcher": []
    },
    {
      "label": "AI: Config Impact",
      "type": "shell",
      "command": "make config-impact WORK_ITEM=${input:workItemId}",
      "problemMatcher": []
    },
    {
      "label": "AI: Config Pack Skeleton",
      "type": "shell",
      "command": "make config-pack-skeleton WORK_ITEM=${input:workItemId}",
      "problemMatcher": []
    },
    {
      "label": "AI: Sync Knowledge Base Dry Run",
      "type": "shell",
      "command": "make knowledge-sync-dry-run KB_REPO=\"${input:kbRepo}\" KB_BRANCH=\"${input:kbBranch}\"",
      "problemMatcher": []
    },
    {
      "label": "AI: Sync Knowledge Base",
      "type": "shell",
      "command": "make knowledge-sync KB_REPO=\"${input:kbRepo}\" KB_BRANCH=\"${input:kbBranch}\"",
      "problemMatcher": []
    },
    {
      "label": "AI: Import Knowledge File",
      "type": "shell",
      "command": "make knowledge-import KNOWLEDGE_SOURCE=\"${input:knowledgeSource}\" KNOWLEDGE_DOMAIN=\"${input:knowledgeDomain}\" KNOWLEDGE_TITLE=\"${input:knowledgeTitle}\" KNOWLEDGE_OWNER=\"${input:knowledgeOwner}\"",
      "problemMatcher": []
    },
    {
      "label": "AI: Import Knowledge Manifest",
      "type": "shell",
      "command": "make knowledge-import-manifest KNOWLEDGE_MANIFEST=\"${input:knowledgeManifest}\"",
      "problemMatcher": []
    },
    {
      "label": "AI: Index Knowledge Base",
      "type": "shell",
      "command": "make knowledge-index",
      "problemMatcher": []
    },
    {
      "label": "AI: Search Knowledge Base",
      "type": "shell",
      "command": "make knowledge-search QUERY=\"${input:contextQuery}\"",
      "problemMatcher": []
    },
    {
      "label": "AI: Knowledge Push Dry Run",
      "type": "shell",
      "command": "make knowledge-push-dry-run KB_REPO=\"${input:kbRepo}\"",
      "problemMatcher": []
    },
    {
      "label": "AI: Knowledge Push",
      "type": "shell",
      "command": "make knowledge-push KB_REPO=\"${input:kbRepo}\"",
      "problemMatcher": []
    },
    {
      "label": "Docs: Build Workspace Documentation",
      "type": "shell",
      "command": "make docs-build",
      "problemMatcher": []
    },
    {
      "label": "Docs: Export PDFs",
      "type": "shell",
      "command": "make docs-export-pdf",
      "problemMatcher": []
    },
    {
      "label": "Docs: Open HTML Runbook",
      "type": "shell",
      "command": "make docs-open-html",
      "problemMatcher": []
    },
    {
      "label": "AI: Start Salesforce Context MCP",
      "type": "shell",
      "command": "make mcp-salesforce-context",
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "sfOrgAlias",
      "type": "promptString",
      "description": "Salesforce org alias for schema/config indexing",
      "default": "IntDev"
    },
    {
      "id": "sfDevOrgAlias",
      "type": "promptString",
      "description": "Salesforce dev org alias",
      "default": "IntDev"
    },
    {
      "id": "sfValidationOrgAlias",
      "type": "promptString",
      "description": "Salesforce validation org alias",
      "default": ""
    },
    {
      "id": "workItemId",
      "type": "promptString",
      "description": "Work Item ID",
      "default": "EXAMPLE-WI"
    },
    {
      "id": "contextQuery",
      "type": "promptString",
      "description": "Context search query",
      "default": "field ui visibility flow config"
    },
    {
      "id": "baseRef",
      "type": "promptString",
      "description": "Git base ref for local Work Item precheck",
      "default": "HEAD~1"
    },
    {
      "id": "kbRepo",
      "type": "promptString",
      "description": "External Knowledge Base Git repository URL or local path",
      "default": ""
    },
    {
      "id": "kbBranch",
      "type": "promptString",
      "description": "External Knowledge Base branch",
      "default": "main"
    },
    {
      "id": "azureWikiRepo",
      "type": "promptString",
      "description": "Azure DevOps Wiki Git repository URL or local path",
      "default": ""
    },
    {
      "id": "azureWikiBranch",
      "type": "promptString",
      "description": "Azure DevOps Wiki base branch",
      "default": "main"
    },
    {
      "id": "azureWikiVendorDir",
      "type": "promptString",
      "description": "Local Azure Wiki clone/cache directory",
      "default": ".ai/vendor/azure-wiki"
    },
    {
      "id": "wikiTitle",
      "type": "promptString",
      "description": "Azure Wiki draft page title",
      "default": "Invoice Approval Routing"
    },
    {
      "id": "wikiSource",
      "type": "promptString",
      "description": "Source documentation artifact path",
      "default": "docs/architecture/EXAMPLE-WI.md"
    },
    {
      "id": "wikiModule",
      "type": "promptString",
      "description": "Optional module-map key",
      "default": ""
    },
    {
      "id": "wikiTargetPath",
      "type": "promptString",
      "description": "Optional explicit Azure Wiki target path",
      "default": ""
    },
    {
      "id": "wikiApprovalNote",
      "type": "promptString",
      "description": "Human approval note for Azure Wiki branch push",
      "default": "Approved by human reviewer"
    },
    {
      "id": "knowledgeSource",
      "type": "promptString",
      "description": "Local knowledge source file",
      "default": ".ai/knowledge/imports/example.txt"
    },
    {
      "id": "knowledgeManifest",
      "type": "promptString",
      "description": "Knowledge import manifest",
      "default": ".ai/templates/knowledge-import-manifest.yaml"
    },
    {
      "id": "knowledgeDomain",
      "type": "promptString",
      "description": "Knowledge domain",
      "default": "general"
    },
    {
      "id": "knowledgeTitle",
      "type": "promptString",
      "description": "Knowledge note title",
      "default": "Example Knowledge Note"
    },
    {
      "id": "knowledgeOwner",
      "type": "promptString",
      "description": "Knowledge note owner",
      "default": "Salesforce Platform Team"
    }
  ]
}
