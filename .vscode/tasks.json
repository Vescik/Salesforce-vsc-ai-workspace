{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "AI Workspace: Setup",
      "type": "shell",
      "command": "pip install -e . --quiet; .\\scripts\\workspace.ps1 setup",
      "problemMatcher": []
    },
    {
      "label": "AI Workspace: Configure",
      "type": "shell",
      "command": ".\\scripts\\workspace.ps1 configure",
      "problemMatcher": []
    },
    {
      "label": "AI Workspace: Doctor",
      "type": "shell",
      "command": ".\\scripts\\workspace.ps1 doctor",
      "problemMatcher": []
    },
    {
      "label": "AI Workspace: Doctor Strict",
      "type": "shell",
      "command": ".\\scripts\\workspace.ps1 doctor-strict",
      "problemMatcher": []
    },
    {
      "label": "AI Workspace: First Run",
      "type": "shell",
      "command": "pip install -e . --quiet; .\\scripts\\workspace.ps1 first-run",
      "problemMatcher": []
    },
    {
      "label": "Salesforce: Login IntDev",
      "type": "shell",
      "command": "sf org login web --alias ${input:sfDevOrgAlias}",
      "problemMatcher": []
    },
    {
      "label": "Knowledge: Sync",
      "type": "shell",
      "command": ".\\scripts\\workspace.ps1 knowledge-sync -KbRepo \"${input:kbRepo}\" -KbBranch \"${input:kbBranch}\"",
      "problemMatcher": []
    },
    {
      "label": "Knowledge: Index",
      "type": "shell",
      "command": ".\\scripts\\workspace.ps1 knowledge-index",
      "problemMatcher": []
    },
    {
      "label": "Azure Wiki: Dry Run Publication",
      "type": "shell",
      "command": ".\\scripts\\workspace.ps1 wiki-dry-run -WorkItem ${input:workItemId} -WikiTitle \"${input:wikiTitle}\" -WikiSource \"${input:wikiSource}\" -AzureWikiRepo \"${input:azureWikiRepo}\" -AzureWikiBranch \"${input:azureWikiBranch}\" -WikiModule \"${input:wikiModule}\" -WikiTargetPath \"${input:wikiTargetPath}\"",
      "problemMatcher": []
    },
    {
      "label": "Azure Wiki: Prepare Draft Branch",
      "type": "shell",
      "command": ".\\scripts\\workspace.ps1 wiki-prepare-branch -WorkItem ${input:workItemId} -WikiTitle \"${input:wikiTitle}\" -WikiSource \"${input:wikiSource}\" -AzureWikiRepo \"${input:azureWikiRepo}\" -AzureWikiBranch \"${input:azureWikiBranch}\" -WikiModule \"${input:wikiModule}\" -WikiTargetPath \"${input:wikiTargetPath}\"",
      "problemMatcher": []
    },
    {
      "label": "Azure Wiki: Push Approved Branch",
      "type": "shell",
      "command": ".\\scripts\\workspace.ps1 wiki-push-approved -WorkItem ${input:workItemId} -WikiTitle \"${input:wikiTitle}\" -WikiSource \"${input:wikiSource}\" -AzureWikiRepo \"${input:azureWikiRepo}\" -AzureWikiBranch \"${input:azureWikiBranch}\" -WikiModule \"${input:wikiModule}\" -WikiTargetPath \"${input:wikiTargetPath}\" -WikiApprovalNote \"${input:wikiApprovalNote}\"",
      "problemMatcher": []
    },
    {
      "label": "Azure Wiki: Scan Wiki",
      "type": "shell",
      "command": ".\\scripts\\workspace.ps1 wiki-scan -AzureWikiVendorDir \"${input:azureWikiVendorDir}\"",
      "problemMatcher": []
    },
    {
      "label": "Context: Build Work Item Context",
      "type": "shell",
      "command": ".\\scripts\\workspace.ps1 ai-context -WorkItem ${input:workItemId} -Query \"${input:contextQuery}\"",
      "problemMatcher": []
    },
    {
      "label": "AI: Index Repo Metadata",
      "type": "shell",
      "command": ".\\scripts\\workspace.ps1 ai-index-repo",
      "problemMatcher": []
    },
    {
      "label": "AI: Index Org Schema",
      "type": "shell",
      "command": ".\\scripts\\workspace.ps1 ai-index-schema -Org ${input:sfOrgAlias}",
      "problemMatcher": []
    },
    {
      "label": "AI: Index Config Records",
      "type": "shell",
      "command": ".\\scripts\\workspace.ps1 ai-index-config -Org ${input:sfOrgAlias}",
      "problemMatcher": []
    },
    {
      "label": "AI: Index All Context",
      "type": "shell",
      "command": ".\\scripts\\workspace.ps1 ai-index-all -Org ${input:sfOrgAlias}",
      "problemMatcher": []
    },
    {
      "label": "AI: Build Context Pack",
      "type": "shell",
      "command": ".\\scripts\\workspace.ps1 ai-context -WorkItem ${input:workItemId} -Query \"${input:contextQuery}\"",
      "problemMatcher": []
    },
    {
      "label": "AI: Build Context Pack From AC",
      "type": "shell",
      "command": ".\\scripts\\workspace.ps1 ai-context-auto -WorkItem ${input:workItemId}",
      "problemMatcher": []
    },
    {
      "label": "AI: Build Example Context Pack",
      "type": "shell",
      "command": ".\\scripts\\workspace.ps1 ai-context-example",
      "problemMatcher": []
    },
    {
      "label": "AI: Check AC Coverage",
      "type": "shell",
      "command": ".\\scripts\\workspace.ps1 ac-coverage -WorkItem ${input:workItemId}",
      "problemMatcher": []
    },
    {
      "label": "AI: Lint Solution Design",
      "type": "shell",
      "command": ".\\scripts\\workspace.ps1 design-lint -WorkItem ${input:workItemId}",
      "problemMatcher": []
    },
    {
      "label": "AI: List Outputs",
      "type": "shell",
      "command": ".\\scripts\\workspace.ps1 ai-list-outputs -WorkItem ${input:workItemId}",
      "problemMatcher": []
    },
    {
      "label": "AI: Check Python Imports",
      "type": "shell",
      "command": ".\\scripts\\workspace.ps1 ai-check-python",
      "problemMatcher": []
    },
    {
      "label": "AI: Run Unit Tests",
      "type": "shell",
      "command": ".\\scripts\\workspace.ps1 test",
      "problemMatcher": []
    },
    {
      "label": "AI: Smoke Test Workspace",
      "type": "shell",
      "command": ".\\scripts\\workspace.ps1 smoke",
      "problemMatcher": []
    },
    {
      "label": "AI: Work Item Precheck",
      "type": "shell",
      "command": ".\\scripts\\workspace.ps1 wi-precheck -WorkItem ${input:workItemId} -BaseRef ${input:baseRef}",
      "problemMatcher": []
    },
    {
      "label": "AI: Work Item Precheck Strict",
      "type": "shell",
      "command": ".\\scripts\\workspace.ps1 wi-precheck-strict -WorkItem ${input:workItemId} -BaseRef ${input:baseRef}",
      "problemMatcher": []
    },
    {
      "label": "AI: Config Impact",
      "type": "shell",
      "command": ".\\scripts\\workspace.ps1 config-impact -WorkItem ${input:workItemId}",
      "problemMatcher": []
    },
    {
      "label": "AI: Config Pack Skeleton",
      "type": "shell",
      "command": ".\\scripts\\workspace.ps1 config-pack-skeleton -WorkItem ${input:workItemId}",
      "problemMatcher": []
    },
    {
      "label": "AI: Sync Knowledge Base Dry Run",
      "type": "shell",
      "command": ".\\scripts\\workspace.ps1 knowledge-sync-dry-run -KbRepo \"${input:kbRepo}\" -KbBranch \"${input:kbBranch}\"",
      "problemMatcher": []
    },
    {
      "label": "AI: Sync Knowledge Base",
      "type": "shell",
      "command": ".\\scripts\\workspace.ps1 knowledge-sync -KbRepo \"${input:kbRepo}\" -KbBranch \"${input:kbBranch}\"",
      "problemMatcher": []
    },
    {
      "label": "AI: Import Knowledge File",
      "type": "shell",
      "command": ".\\scripts\\workspace.ps1 knowledge-import -KnowledgeSource \"${input:knowledgeSource}\" -KnowledgeDomain \"${input:knowledgeDomain}\" -KnowledgeTitle \"${input:knowledgeTitle}\" -KnowledgeOwner \"${input:knowledgeOwner}\"",
      "problemMatcher": []
    },
    {
      "label": "AI: Import Knowledge Manifest",
      "type": "shell",
      "command": ".\\scripts\\workspace.ps1 knowledge-import-manifest -KnowledgeManifest \"${input:knowledgeManifest}\"",
      "problemMatcher": []
    },
    {
      "label": "AI: Validate Knowledge Base",
      "type": "shell",
      "command": ".\\scripts\\workspace.ps1 knowledge-validate",
      "problemMatcher": []
    },
    {
      "label": "AI: Index Metadata Knowledge",
      "type": "shell",
      "command": ".\\scripts\\workspace.ps1 metadata-knowledge-index",
      "problemMatcher": []
    },
    {
      "label": "AI: Emit Knowledge YAML Index",
      "type": "shell",
      "command": ".\\scripts\\workspace.ps1 knowledge-index-yaml",
      "problemMatcher": []
    },
    {
      "label": "AI: Build Knowledge Graph",
      "type": "shell",
      "command": ".\\scripts\\workspace.ps1 knowledge-graph",
      "problemMatcher": []
    },
    {
      "label": "AI: Index Knowledge Base",
      "type": "shell",
      "command": ".\\scripts\\workspace.ps1 knowledge-index",
      "problemMatcher": []
    },
    {
      "label": "AI: Search Knowledge Base",
      "type": "shell",
      "command": ".\\scripts\\workspace.ps1 knowledge-search -Query \"${input:contextQuery}\"",
      "problemMatcher": []
    },
    {
      "label": "AI: Knowledge Push Dry Run",
      "type": "shell",
      "command": ".\\scripts\\workspace.ps1 knowledge-push-dry-run -KbRepo \"${input:kbRepo}\"",
      "problemMatcher": []
    },
    {
      "label": "AI: Knowledge Push",
      "type": "shell",
      "command": ".\\scripts\\workspace.ps1 knowledge-push -KbRepo \"${input:kbRepo}\"",
      "problemMatcher": []
    },
    {
      "label": "Docs: Build Workspace Documentation",
      "type": "shell",
      "command": ".\\scripts\\workspace.ps1 docs-build",
      "problemMatcher": []
    },
    {
      "label": "Docs: Export PDFs",
      "type": "shell",
      "command": ".\\scripts\\workspace.ps1 docs-export-pdf",
      "problemMatcher": []
    },
    {
      "label": "Docs: Open HTML Runbook",
      "type": "shell",
      "command": ".\\scripts\\workspace.ps1 docs-open-html",
      "problemMatcher": []
    },
    {
      "label": "AI: Start Salesforce Context MCP",
      "type": "shell",
      "command": ".\\scripts\\workspace.ps1 mcp-salesforce-context",
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "sfOrgAlias",
      "type": "promptString",
      "description": "Salesforce org alias for schema/config indexing",
      "default": "IntDev"
    },
    {
      "id": "sfDevOrgAlias",
      "type": "promptString",
      "description": "Salesforce dev org alias",
      "default": "IntDev"
    },
    {
      "id": "sfValidationOrgAlias",
      "type": "promptString",
      "description": "Salesforce validation org alias",
      "default": ""
    },
    {
      "id": "workItemId",
      "type": "promptString",
      "description": "Work Item ID",
      "default": "EXAMPLE-WI"
    },
    {
      "id": "contextQuery",
      "type": "promptString",
      "description": "Context search query",
      "default": "field ui visibility flow config"
    },
    {
      "id": "baseRef",
      "type": "promptString",
      "description": "Git base ref for local Work Item precheck",
      "default": "HEAD~1"
    },
    {
      "id": "kbRepo",
      "type": "promptString",
      "description": "External Knowledge Base Git repository URL or local path",
      "default": ""
    },
    {
      "id": "kbBranch",
      "type": "promptString",
      "description": "External Knowledge Base branch",
      "default": "main"
    },
    {
      "id": "azureWikiRepo",
      "type": "promptString",
      "description": "Azure DevOps Wiki Git repository URL or local path",
      "default": ""
    },
    {
      "id": "azureWikiBranch",
      "type": "promptString",
      "description": "Azure DevOps Wiki base branch",
      "default": "main"
    },
    {
      "id": "azureWikiVendorDir",
      "type": "promptString",
      "description": "Local Azure Wiki clone/cache directory",
      "default": ".ai/vendor/azure-wiki"
    },
    {
      "id": "wikiTitle",
      "type": "promptString",
      "description": "Azure Wiki draft page title",
      "default": "Invoice Approval Routing"
    },
    {
      "id": "wikiSource",
      "type": "promptString",
      "description": "Source documentation artifact path",
      "default": "docs/architecture/EXAMPLE-WI.md"
    },
    {
      "id": "wikiModule",
      "type": "promptString",
      "description": "Optional module-map key",
      "default": ""
    },
    {
      "id": "wikiTargetPath",
      "type": "promptString",
      "description": "Optional explicit Azure Wiki target path",
      "default": ""
    },
    {
      "id": "wikiApprovalNote",
      "type": "promptString",
      "description": "Human approval note for Azure Wiki branch push",
      "default": "Approved by human reviewer"
    },
    {
      "id": "knowledgeSource",
      "type": "promptString",
      "description": "Local knowledge source file",
      "default": ".ai/knowledge/imports/example.txt"
    },
    {
      "id": "knowledgeManifest",
      "type": "promptString",
      "description": "Knowledge import manifest",
      "default": ".ai/templates/knowledge-import-manifest.yaml"
    },
    {
      "id": "knowledgeDomain",
      "type": "promptString",
      "description": "Knowledge domain",
      "default": "general"
    },
    {
      "id": "knowledgeTitle",
      "type": "promptString",
      "description": "Knowledge note title",
      "default": "Example Knowledge Note"
    },
    {
      "id": "knowledgeOwner",
      "type": "promptString",
      "description": "Knowledge note owner",
      "default": "Salesforce Platform Team"
    }
  ]
}
